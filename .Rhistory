tabla_desc <- base %>%
summarise(
`Log salario (media)`          = round(mean(logw, na.rm = TRUE), 3),
`Log salario (sd)`             = round(sd(logw, na.rm = TRUE), 3),
`Log salario (p25)`            = round(quantile(logw, 0.25, na.rm = TRUE), 3),
`Log salario (p75)`            = round(quantile(logw, 0.75, na.rm = TRUE), 3),
`Edad (media)`                 = round(mean(age, na.rm = TRUE), 1),
`Edad (sd)`                    = round(sd(age, na.rm = TRUE), 1),
`Horas trabajadas (media)`     = round(mean(totalHoursWorked, na.rm = TRUE), 1),
`Horas trabajadas (sd)`        = round(sd(totalHoursWorked, na.rm = TRUE), 1),
`Antigüedad en el empleo (media)` = round(mean(p6426, na.rm = TRUE), 1),
`Antigüedad en el empleo (sd)`    = round(sd(p6426, na.rm = TRUE), 1),
`Tamaño firma (media)`         = round(mean(sizeFirm, na.rm = TRUE), 1),
`Proporción mujeres (%)`       = round(100 * mean(female, na.rm = TRUE), 1),
`Proporción con salud contrib. (%)` = round(100 * mean(regSalud == 1, na.rm = TRUE), 1),
`N observaciones`              = n()
) %>%
pivot_longer(everything(), names_to = "Variable", values_to = "Valor")
